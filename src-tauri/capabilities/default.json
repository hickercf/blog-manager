{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "fs:default",
    "fs:read-all",
    "fs:write-all",
    "fs:allow-remove",
    {
      "identifier": "fs:scope",
      "allow": [{"path": "**"}]
    },
    "shell:default",
    "dialog:default",
    "dialog:allow-open",
    "shell:allow-execute",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "args": true,
          "cmd": "cmd",
          "name": "cmd"
        },
        {
          "args": true,
          "cmd": "hexo",
          "name": "hexo"
        },
        {
          "args": true,
          "cmd": "npx",
          "name": "npx"
        },
        {
          "args": true,
          "cmd": "npm",
          "name": "npm"
        },
        {
          "args": true,
          "cmd": "node",
          "name": "node"
        },
        {
          "args": true,
          "cmd": "D:\\hickercf_blog\\blog\\node_modules\\.bin\\hexo.cmd",
          "name": "hexo-local"
        },
        {
          "args": true,
          "cmd": "D:\\hickercf_blog\\blog\\node_modules\\.bin\\npx.cmd",
          "name": "npx-local"
        }
      ]
    }
  ]
}
